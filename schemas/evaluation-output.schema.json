{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/evaluation-output.schema.json",
  "title": "Job Evaluation Output Schema",
  "description": "Structured output produced by the Job Evaluation Engine.",
  "type": "object",

  "required": [
    "job",
    "candidate",
    "capability_profile",
    "evaluation",
    "summary",
    "metadata"
  ],

  "properties": {
    "job": {
      "type": "object",
      "required": ["title", "company"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "company": {
          "type": "string",
          "minLength": 1
        },
        "location": {
          "type": ["string", "null"]
        },
        "source": {
          "type": ["string", "null"],
          "description": "Source of job listing"
        }
      },
      "additionalProperties": false
    },

    "candidate": {
      "type": "object",
      "required": ["profile_id"],
      "properties": {
        "profile_id": {
          "type": "string",
          "description": "Identifier for candidate profile"
        }
      },
      "additionalProperties": false
    },

    "capability_profile": {
      "type": "object",
      "description": "Multidimensional capability vector produced by the lattice model",
      "required": [
        "reasoning",
        "planning",
        "creativity",
        "operational_complexity",
        "coordination"
      ],
      "properties": {
        "reasoning": { "$ref": "#/$defs/scoreValue" },
        "planning": { "$ref": "#/$defs/scoreValue" },
        "creativity": { "$ref": "#/$defs/scoreValue" },
        "operational_complexity": { "$ref": "#/$defs/scoreValue" },
        "coordination": { "$ref": "#/$defs/scoreValue" }
      },
      "additionalProperties": false
    },

    "evaluation": {
      "type": "object",
      "description": "Evaluation metrics derived from the capability profile",
      "required": ["alignment_score", "gap_analysis"],
      "properties": {
        "alignment_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Overall candidate-role alignment score"
        },

        "gap_analysis": {
          "type": "object",
          "description": "Differences between candidate and role capability vectors",
          "properties": {
            "reasoning": { "$ref": "#/$defs/gapValue" },
            "planning": { "$ref": "#/$defs/gapValue" },
            "creativity": { "$ref": "#/$defs/gapValue" },
            "operational_complexity": { "$ref": "#/$defs/gapValue" },
            "coordination": { "$ref": "#/$defs/gapValue" }
          },
          "additionalProperties": false
        },

        "confidence": {
          "type": "string",
          "enum": ["LOW", "MEDIUM", "HIGH"]
        }
      },
      "additionalProperties": false
    },

    "summary": {
      "type": "string",
      "minLength": 10,
      "maxLength": 2000
    },

    "metadata": {
      "type": "object",
      "required": ["evaluation_version", "timestamp"],
      "properties": {
        "evaluation_version": {
          "type": "string",
          "description": "Version of scoring model"
        },

        "timestamp": {
          "type": "string",
          "format": "date-time"
        },

        "model": {
          "type": ["string", "null"],
          "description": "LLM used for evaluation"
        },

        "config_profile": {
          "type": ["string", "null"],
          "description": "Configuration profile used"
        }
      },
      "additionalProperties": false
    }
  },

  "$defs": {
    "scoreValue": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },

    "gapValue": {
      "type": "number",
      "minimum": -1,
      "maximum": 1
    }
  },

  "additionalProperties": false
}
